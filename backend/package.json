{
  "name": "clienthub-backend",
  "version": "1.0.0",
  "description": "ClientHub Backend API - White-label client portal for agencies",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/**/*.test.js",
    "test:smoke": "node --test test/api.smoke.test.js",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov npm test",
    "test:coverage:check": "c8 --check-coverage --lines 30 --functions 5 --branches 20 --statements 30 npm test",
    "migrate": "node scripts/migrate.mjs"
  },
  "keywords": [
    "client-portal",
    "agency",
    "white-label",
    "crm"
  ],
  "author": "Faith Harbor",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^171.4.0",
    "heic-convert": "^2.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "openai": "^6.25.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "square": "^44.0.0",
    "stripe": "^14.7.0",
    "twilio": "^5.12.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "nodemon": "^3.0.2"
  }
}
