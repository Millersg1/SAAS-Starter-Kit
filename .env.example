# ===========================================
# ClientHub - Environment Variables
# ===========================================

# Database Configuration
DATABASE_URL=postgresql://faithharborclien_usercliENt:11809Mills!@localhost:5432/faithharborclien_clienthub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=faithharborclien_clienthub
DB_USER=faithharborclien_usercliENt
DB_PASSWORD=11809Mills!

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
PORTAL_TOKEN_EXPIRE=7d

# Application
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (SMTP)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_NAME=ClientHub
SMTP_FROM_EMAIL=noreply@yourdomain.com

# File Storage
STORAGE_TYPE=local
# For local storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# 50MB in bytes

# For S3 storage (optional)
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=clienthub-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# Session
SESSION_SECRET=your-session-secret-change-this

# CORS
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Admin
ADMIN_EMAIL=admin@clienthub.com
ADMIN_PASSWORD=Admin123!

# Features
ENABLE_REALTIME=false
# Set to true if using Socket.io
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true
